// Settings used only by the signed, notarized distribution archive.
// The GitHub Actions workflow supplies DEVELOPMENT_TEAM and the full identity.
ARCHS = arm64 x86_64
ONLY_ACTIVE_ARCH = NO
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY[sdk=macosx*] = $(APPLE_DEVELOPER_IDENTITY)
ENABLE_HARDENED_RUNTIME = YES
SWIFT_DEFAULT_ACTOR_ISOLATION = MainActor
